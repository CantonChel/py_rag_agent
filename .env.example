# ============================================================
#                    RAG系统环境变量配置
# ============================================================
# 使用方法：
# 1. 复制此文件并重命名为 .env
# 2. 填写你的实际配置值
# 3. 确保 .env 文件不被提交到git（已在.gitignore中）
# ============================================================

# -----------------------------------------------------------
# 【大语言模型配置】
# -----------------------------------------------------------
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4-turbo

# -----------------------------------------------------------
# 【Embedding模型配置】
# -----------------------------------------------------------
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL_NAME=text-embedding-3-small

# -----------------------------------------------------------
# 【Rerank模型配置】（可选）
# -----------------------------------------------------------
ENABLE_RERANK=false
RERANK_API_KEY=your-rerank-api-key-here
RERANK_BASE_URL=https://api.cohere.ai/v1
RERANK_MODEL_NAME=rerank-multilingual-v3.0

# -----------------------------------------------------------
# 【MinIO对象存储配置】
# 用于存储上传的原始文件
# -----------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

# -----------------------------------------------------------
# 【PostgreSQL + pgvector配置】
# 用于存储文本块和向量
# -----------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=rag_db

# -----------------------------------------------------------
# 【Redis配置】（可选）
# -----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------
# 【应用配置】
# -----------------------------------------------------------
LOG_LEVEL=INFO
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# API服务配置
API_HOST=0.0.0.0
API_PORT=8000

# 文件上传配置
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.html,.md,.txt
